{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/app.html" },
    { "src": "^/app$", "dest": "/app.html" },
    { "src": "^/api/(.*)", "dest": "/api/$1" },
    { "src": "^/css/(.*)", "dest": "/css/$1" },
    { "src": "^/js/(.*)", "dest": "/js/$1" },
    { "src": "^/(.*)\\.html$", "dest": "/$1.html" }
  ]
}
